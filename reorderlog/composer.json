{
    "name": "fieldtrial/reorderlog",
    "description": "FT352 — 一括並べ替え（drag-and-drop ordering）: CASE WHEN 2フェーズ更新・UNIQUE(position) 衝突回避・IDOR 防御",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "ReorderLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ReorderLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
