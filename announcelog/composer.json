{
    "name": "fieldtrial/announcelog",
    "description": "FT190 — システムアナウンス管理: hash_equals 定数時間 admin key・UTC 時刻フィルタ・冪等 dismissal",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5.327"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "AnnounceLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AnnounceLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
