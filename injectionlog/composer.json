{
    "name": "ft/injectionlog",
    "description": "FT97: SQL injection — parameterized queries, LIKE injection, ORDER BY injection field trial",
    "type": "project",
    "require": {
        "php": ">=8.4.1",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "phpstan/phpstan": "^2",
        "friendsofphp/php-cs-fixer": "^3"
    },
    "autoload": {
        "psr-4": {
            "Injection\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Injection\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@cs", "@analyse", "@test"]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
