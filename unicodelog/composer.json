{
    "name": "fieldtrial/unicodelog",
    "description": "FT345 — Unicode 安全テキスト API: mb_strlen 文字数カウント・null バイト拒否・多言語/絵文字/ZWJ 対応・JSON 配列タグ",
    "type": "project",
    "require": {
        "php": "^8.4",
        "ext-mbstring": "*",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "UnicodeLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "UnicodeLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
