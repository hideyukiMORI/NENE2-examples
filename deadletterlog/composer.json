{
    "name": "fieldtrial/deadletterlog",
    "description": "FT72 — デッドレターキュー: 指数バックオフ再試行・DLQ 昇格・replay・named queue・原子的 claim (transactional)",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "DeadLetterLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeadLetterLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
