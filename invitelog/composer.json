{
    "name": "nene2-ft/invitelog",
    "description": "FT124 — User Invitation System",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "hideyukimori/nene2": "^1.5",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Invitation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Invitation\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff --allow-risky=yes",
        "cs:fix": "php-cs-fixer fix --allow-risky=yes",
        "check": ["@cs", "@analyse", "@test"]
    },
    "config": {
        "sort-packages": true
    }
}
