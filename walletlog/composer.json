{
    "name": "fieldtrial/walletlog",
    "description": "FT198 — 多通貨ウォレット: 入金/出金/送金・最小単位整数・transactional 送金・IDOR・通貨allowlist",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "WalletLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WalletLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
