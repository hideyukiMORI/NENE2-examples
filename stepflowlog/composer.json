{
    "name": "stepflowlog/stepflowlog",
    "description": "FT166: Multi-step Workflow approval pattern with NENE2",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "hideyukimori/nene2": "^1.5",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "StepFlow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StepFlow\\Tests\\": "tests/"
        }
    }
}
