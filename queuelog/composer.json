{
    "name": "nene2-ft/queuelog",
    "description": "FT116 — Background Job Queue with Retry and Idempotency",
    "type": "project",
    "require": {
        "hideyukimori/nene2": "^1.5",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Queue\\": "src/Queue/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Queue\\Tests\\": "tests/Queue/"
        }
    },
    "scripts": {
        "test": "php vendor/bin/phpunit",
        "analyse": "php vendor/bin/phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php vendor/bin/php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    },
    "config": {
        "sort-packages": true
    }
}
