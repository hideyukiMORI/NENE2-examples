{
    "name": "fieldtrial/assetlog",
    "description": "FT194 — 資産チェックアウト/チェックイン: 排他ホールド・追記監査ログ・IDOR 防御・admin キー",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "AssetLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AssetLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
