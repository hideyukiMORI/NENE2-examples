{
    "name": "fieldtrial/statslog",
    "description": "FT51 — イベント分析 API: json_extract プロパティ絞り込み・strftime 日次バケット・COUNT(DISTINCT) ユニークユーザー・静的ルート優先",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "StatsLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StatsLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
