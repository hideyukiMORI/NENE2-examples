{
    "name": "fieldtrial/tagfilterlog",
    "description": "FT250 — 複数タグフィルタ: M:N join・AND (HAVING COUNT DISTINCT) / OR (SELECT DISTINCT)・CSV と tags[] 両対応クエリ",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "TagFilterLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TagFilterLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
