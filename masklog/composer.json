{
    "name": "masklog/masklog",
    "description": "FT169: Data Masking with PII field masking, admin unmask with audit log",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "hideyukimori/nene2": "^1.5",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "MaskLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MaskLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --testdox",
        "analyse": "vendor/bin/phpstan analyse --level=8 src tests",
        "cs": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs:fix": "vendor/bin/php-cs-fixer fix",
        "check": ["@cs", "@analyse", "@test"]
    }
}
