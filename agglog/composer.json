{
    "name": "agglog/agglog",
    "description": "FT168: Admin Report Aggregation with date-range filters",
    "type": "project",
    "require": {
        "php": ">=8.4",
        "hideyukimori/nene2": "^1.5",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": { "AggLog\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "AggLog\\Tests\\": "tests/" }
    }
}
