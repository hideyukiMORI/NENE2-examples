{
    "name": "fieldtrial/paymentlog",
    "description": "FT163 — Payment Webhook 受信 API（HMAC-SHA256 署名検証・冪等処理・ステータス遷移）",
    "type": "project",
    "require": {
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PaymentLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PaymentLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
