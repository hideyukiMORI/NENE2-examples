{
    "name": "fieldtrial/bulkupdatelog",
    "description": "FT85 — 一括ステータス更新: per-item / homogeneous バルク更新・部分成功・TaskStatus enum allowlist・所有者スコープ (FT231 VULN ハードニング)",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "BulkUpdateLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BulkUpdateLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
