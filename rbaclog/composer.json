{
    "name": "ft/rbaclog",
    "description": "FT111 — Role-Based Access Control (RBAC) with JWT claims",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.75"
    },
    "autoload": {
        "psr-4": {
            "Rbac\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rbac\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "vendor/bin/php-cs-fixer check --diff --allow-risky=yes",
        "cs:fix": "vendor/bin/php-cs-fixer fix --allow-risky=yes",
        "check": [
            "@test",
            "@analyse",
            "@cs"
        ]
    }
}
