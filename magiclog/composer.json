{
    "name": "nene2-ft/magiclog",
    "description": "FT144: Passwordless Auth (Magic Link)",
    "type": "project",
    "require": {
        "php": ">=8.4.1 <9.0",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "MagicLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MagicLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "analyse": "phpstan analyse --level=8 src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@cs", "@analyse", "@test"]
    },
    "config": {
        "sort-packages": true
    }
}
