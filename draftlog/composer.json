{
    "name": "fieldtrial/draftlog",
    "description": "FT142 — コンテンツ下書きライフサイクル: ArticleStatus enum 状態機械・遷移ガード・著者可視性 (draft は 404 で隠す)・同一秒ソート安定化",
    "type": "project",
    "require": {
        "php": "^8.4",
        "hideyukimori/nene2": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "DraftLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DraftLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --level=8 --memory-limit=512M src tests",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "check": ["@test", "@analyse", "@cs"]
    }
}
